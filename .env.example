DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crm_vet?schema=public"
APP_URL="http://localhost:3000"
SESSION_SECRET="cambiar-por-un-secreto-largo-generado-con-openssl-rand--base64-32"
INTERNAL_WHATSAPP_TOKEN="cambiar-por-un-secreto-largo"
WHATSAPP_CLINIC_KEY="patitas-demo"
